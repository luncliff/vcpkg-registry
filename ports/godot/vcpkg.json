{
  "name": "godot",
  "version": "4.2.1",
  "description": "Godot Engine – Multi-platform 2D and 3D game engine",
  "homepage": "https://github.com/godotengine/godot",
  "license": "MIT",
  "supports": "windows | osx | linux",
  "dependencies": [
    "basisu",
    "brotli",
    "embree3",
    "enet",
    "etcpak",
    {
      "name": "freetype",
      "features": [
        "brotli",
        "zlib"
      ]
    },
    {
      "name": "glad",
      "features": [
        "loader"
      ]
    },
    "glslang",
    {
      "name": "harfbuzz",
      "features": [
        "graphite2",
        "icu"
      ]
    },
    "icu",
    "libogg",
    "libpng",
    "libsquish",
    "libtheora",
    "libvorbis",
    "libwebp",
    "mbedtls",
    "meshoptimizer",
    "minimp3",
    "miniupnpc",
    "minizip",
    "msdfgen",
    "openxr-loader",
    "pcg",
    "pcre2",
    "rvo2",
    "rvo2-3d",
    "tinyexr",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    {
      "name": "vcpkg-get-python-packages",
      "host": true
    },
    "xatlas",
    "zlib",
    "zstd"
  ],
  "features": {
    "gles3": {
      "description": "Build with OpenGL ES",
      "supports": "windows",
      "dependencies": [
        {
          "name": "angle",
          "platform": "windows"
        },
        {
          "name": "glad",
          "features": [
            "gles2-api-30",
            "gles2-api-31",
            "gles2-api-latest"
          ],
          "platform": "windows"
        }
      ]
    },
    "test": {
      "description": "Build test programs",
      "dependencies": [
        "doctest"
      ]
    },
    "vulkan": {
      "description": "Build with Vulkan SDK",
      "dependencies": [
        {
          "name": "openxr-loader",
          "features": [
            "vulkan"
          ]
        },
        "vulkan"
      ]
    }
  }
}
